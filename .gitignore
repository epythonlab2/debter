# ======================================================
# Dependencies
# ======================================================
node_modules/

# ======================================================
# Build Outputs (Web)
# ======================================================
dist/
dist-ssr/
build/

# ======================================================
# React Native Bundles (keep if legacy, harmless)
# ======================================================
*.jsbundle

# ======================================================
# Generated Mobile Builds (ARTIFACTS ONLY)
# ======================================================
*.apk
*.aab
*.ipa

# ======================================================
# Environment Variables
# ======================================================
.env
.env.*
!.env.example
*.local

# ======================================================
# Logs
# ======================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ======================================================
# TypeScript
# ======================================================
*.tsbuildinfo

# ======================================================
# Testing & Coverage
# ======================================================
coverage/
.nyc_output/
jest-cache/

# ======================================================
# React / tooling
# ======================================================
.expo/
.expo-shared/
.metro-health-check*

# ======================================================
# Capacitor (IMPORTANT FIX)
# ======================================================

# ❌ DO NOT ignore entire android/ or ios/
# They are part of project state and required for reproducible builds

# ✔ Ignore ONLY generated build artifacts inside native projects
android/
android/.gradle/
android/app/build/
android/build/
android/local.properties

ios/build/
ios/App/build/
ios/App/Pods/
ios/Pods/
ios/.xcode.env.local

# ======================================================
# Signing Keys (SECURITY CRITICAL)
# ======================================================
*.keystore
*.jks

# ======================================================
# Supabase
# ======================================================
supabase/.temp/
supabase/.branches/

# ======================================================
# Firebase (Optional)
# ======================================================
google-services.json
GoogleService-Info.plist

# ======================================================
# IDEs & Editors
# ======================================================
.vscode/*
!.vscode/extensions.json
.idea/

*.suo
*.ntvs*
*.njsproj
*.sln

# ======================================================
# Vim
# ======================================================
*.sw?
*.swp
*.swo

# ======================================================
# Operating System Files
# ======================================================
.DS_Store
Thumbs.db

# ======================================================
# Temporary Files
# ======================================================
tmp/
temp/
